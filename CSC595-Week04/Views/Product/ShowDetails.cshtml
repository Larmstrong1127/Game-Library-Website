@model Product
@using CSC595_Week04.Models

@{
    ViewData["Title"] = "Game Details";
    Layout = "_Layout";
}

@if (Model is null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-circle me-2"></i>
        No game found with ID @ViewBag.id.
    </div>
    <a asp-controller="Product" asp-action="Index" class="btn btn-secondary mt-2">
        <i class="bi bi-arrow-left me-1"></i>Back to Library
    </a>
}
else
{
    <div class="page-header">
        <h1><i class="bi bi-info-circle-fill text-accent me-2"></i>Game Details</h1>
        <a asp-controller="Product" asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Library
        </a>
    </div>

    <div class="detail-card d-flex gap-4 flex-wrap">
        <!-- Cover image -->
        <div>
            @if (ViewBag.productProfilePhoto != null)
            {
                <img src="@ViewBag.productProfilePhoto"
                     alt="@Model.Name cover"
                     style="height:220px; object-fit:cover;" />
            }
            else
            {
                <img src="~/images/defaultgame.jpg"
                     alt="Default game cover"
                     style="height:220px; object-fit:cover;" />
            }
        </div>

        <!-- Game info -->
        <div>
            <h2 class="mb-1">@Model.Name</h2>
            <p class="text-muted mb-3">ID: @Model.Id</p>
            <p class="mb-1">
                <span class="text-muted small">Price</span>
            </p>
            <span class="badge-price" style="font-size:1.1rem;">
                $@Model.Price.ToString("F2")
            </span>

            @if (User.Identity.IsAuthenticated)
            {
                <div class="d-flex gap-2 mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Delete
                    </a>
                </div>
            }
        </div>
    </div>
}
