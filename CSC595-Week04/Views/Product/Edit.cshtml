@model Product
@using CSC595_Week04.Models

@{
    ViewData["Title"] = "Edit Game";
    Layout = "_Layout";
}

<div class="page-header">
    <h1><i class="bi bi-pencil-fill text-accent me-2"></i>Edit Game</h1>
    <a asp-action="Index" asp-controller="Product" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Library
    </a>
</div>

<form asp-action="Edit" method="post" style="max-width:520px;">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
    <input type="hidden" asp-for="Id" />

    <div class="form-group mb-3">
        <label asp-for="Name" class="form-label">Game Name</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger small"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Genre" class="form-label">Genre</label>
        <select asp-for="Genre" class="form-control">
            @foreach (var g in (string[])ViewBag.Genres)
            {
                <option value="@g" selected="@(Model.Genre == g)">@g</option>
            }
        </select>
        <span asp-validation-for="Genre" class="text-danger small"></span>
    </div>

    <div class="form-group mb-4">
        <label asp-for="Price" class="form-label">Price ($)</label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger small"></span>
    </div>

    <div class="d-flex gap-2">
        <input type="submit" value="Save Changes" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>
