@model Product
@using CSC595_Week04.Models

@{
    ViewData["Title"] = "Add Game";
    Layout = "_Layout";
}

<div class="page-header">
    <h1><i class="bi bi-plus-circle-fill text-accent me-2"></i>Add New Game</h1>
    <a asp-action="Index" asp-controller="Product" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Library
    </a>
</div>

<form asp-action="Add" method="post" enctype="multipart/form-data" style="max-width:520px;">

    <div class="form-group mb-3">
        <label asp-for="Name" class="form-label">Game Name</label>
        <input asp-for="Name" class="form-control" placeholder="e.g. The Legend of Zelda" />
        <span asp-validation-for="Name" class="text-danger small"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Genre" class="form-label">Genre</label>
        <select asp-for="Genre" class="form-control">
            @foreach (var g in Product.Genres)
            {
                <option value="@g">@g</option>
            }
        </select>
        <span asp-validation-for="Genre" class="text-danger small"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Price" class="form-label">Price ($)</label>
        <input asp-for="Price" class="form-control" placeholder="e.g. 59.99" />
        <span asp-validation-for="Price" class="text-danger small"></span>
    </div>

    <div class="form-group mb-4">
        <label class="form-label">Cover Image <span class="text-muted small">(optional)</span></label>
        <input type="file" name="ImageDataForProduct" class="form-control" accept="image/*" />
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-circle me-1"></i>Add Game
        </button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>

</form>
